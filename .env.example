# =============================================================================
# 1024 Multi-Agent Deep Research Oracle — Environment Template
# Copy to .env.local / .env.staging / .env.production and fill values
# =============================================================================

# -----------------------------------------------------------------------------
# AI Provider API Keys
# -----------------------------------------------------------------------------

# Vertex AI Mode (required — the only supported auth method)
USE_VERTEX_AI=true
VERTEX_AI_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1
# GCP 服务账户 JSON 注入 (用途: AI 深度研究 Agent 调用 Gemini API)
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...",...}

# NOTE: GEMINI_API_KEY / AI Studio mode has been permanently removed (2026-03-29).
# This project uses Vertex AI exclusively. Do NOT add GEMINI_API_KEY here.

GEMINI_MODEL=gemini-2.5-flash

# Optional providers
# OPENAI_API_KEY=your-openai-key
# ANTHROPIC_API_KEY=your-anthropic-key

# -----------------------------------------------------------------------------
# IPFS Storage - Storacha (https://console.storacha.network/)
# -----------------------------------------------------------------------------

STORACHA_SPACE_DID=did:key:your-space-did
IPFS_GATEWAY=https://storacha.link
STORACHA_USE_CLI=true

# -----------------------------------------------------------------------------
# Oracle Configuration
# -----------------------------------------------------------------------------

MIN_AGENTS=3
MIN_VALID_AGENTS=2
REQUIRE_UNANIMOUS=false
CONSENSUS_THRESHOLD=0.66
MAX_CONSENSUS_ROUNDS=5
MIN_SOURCES_PER_AGENT=1
RESEARCH_TIMEOUT=300

# -----------------------------------------------------------------------------
# API Server Configuration
# -----------------------------------------------------------------------------

API_HOST=0.0.0.0
API_PORT=8989
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING (production)
DEBUG=false
